# ════════════════════════════════════════════════════════
# UrbanLux Pro — Zmienne środowiskowe BACKEND (Render)
# Skopiuj do .env lokalnie (NIE commituj .env do git!)
# ════════════════════════════════════════════════════════

# Supabase — połączenie z bazą danych
# Znajdziesz w: Supabase Dashboard → Settings → Database → Connection string → URI
# WAŻNE: Użyj "Transaction Pooler" (port 6543) dla Render!
DATABASE_URL="postgresql://postgres.TWOJ_PROJECT_ID:TWOJE_HASLO@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Google Maps API Key (opcjonalne — dla Street View proxy)
GOOGLE_MAPS_KEY=

# URL frontendu (dla CORS) — wstaw po deploymencie na Netlify
FRONTEND_URL=https://twoja-domena.netlify.app

# Port (Render ustawia automatycznie — nie zmieniaj)
# PORT=3000
